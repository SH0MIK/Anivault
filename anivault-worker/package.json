    "bcryptjs": "^2.4.3",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241205.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.7.2",
    "wrangler": "^3.90.0"
  }
}
